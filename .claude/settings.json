{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(date:*)",
      "Bash(touch:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/health-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-gate.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/retry-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/bash-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|Skill",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/workflow-tracker.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
