{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(date:*)",
      "Bash(touch:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
