{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(date:*)",
      "Bash(touch:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check the conversation: were any files created or modified? If so, were they staged with git add? If tests exist for changed code, were they run? Respond {\"decision\": \"block\", \"reason\": \"Unstaged files or untested changes remain\"} only if files were clearly changed but NOT staged. Otherwise respond {}."
          }
        ]
      }
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
